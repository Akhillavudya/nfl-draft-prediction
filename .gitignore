# ── Virtual environment ───────────────────────────────────────────────
venv/

# ── Data (large; possibly redistribution-restricted) ──────────────────
data/raw/*.csv
data/processed/*

# ── Generated model artifacts & training logs ─────────────────────────
models/*.joblib
models/*.cbm
catboost_info/

# ── Generated outputs ─────────────────────────────────────────────────
submission_*.csv
submission.zip
reports/figures/*.png
# Exception: the SHAP figure is a portfolio deliverable, tracked on purpose.
!reports/figures/shap_importance.png

# ── Experiment tracking (added in a later phase) ──────────────────────
wandb/

# ── Gradio UI runtime cruft (Phase E) ─────────────────────────────────
flagged/
.gradio/

# ── Secrets ───────────────────────────────────────────────────────────
.env

# ── Python cruft ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# ── Keep empty dirs tracked (see .gitkeep files) ──────────────────────
!data/raw/.gitkeep
!data/processed/.gitkeep
!models/.gitkeep
!reports/figures/.gitkeep
